# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environment ───────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Secrets / env files ───────────────────────────────────────
.env
.streamlit/secrets.toml

# ── Model weights (large binary — keep out of git) ────────────
saved_model/*.h5
saved_model/*.keras
saved_model/*.pkl

# ── Generated outputs ─────────────────────────────────────────
evaluation_plots/
/*.csv
*.zip

# ── Allow datasets directory (real-world data) ────────────────
!datasets/
# Exclude large raw source files (>10MB — use fetch_azure_pdm.py to regenerate)
datasets/_pdm_telemetry_raw.csv
datasets/_pdm_failures_raw.csv
datasets/azure_pdm_full.csv
datasets/azure_pdm_full_fault_log.csv

# ── IDE / OS ──────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
generated_reports/